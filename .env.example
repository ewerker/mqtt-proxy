# Meshtastic MQTT Proxy example configuration
# Copy this file to `.env` and adjust the values for your machine.
#
# Important:
# - MQTT broker address, user, password, TLS, and root topic are normally read
#   from the connected Meshtastic device.
# - This file mainly controls HOW the proxy runs locally:
#   serial/TCP, logging, listener behavior, node list export, queue handling, etc.
# - Boolean values use `true` or `false`.

# ---------------------------------------------------------------------------
# Interface / connection
# ---------------------------------------------------------------------------
# Choose how the proxy talks to your Meshtastic node.
# - `serial` is the normal USB case.
# - `tcp` is useful for virtual nodes, remote endpoints, or test setups.
INTERFACE_TYPE=serial

# Serial device path or automatic detection.
# - `auto` tries to pick a likely Meshtastic USB port.
# - Typical values:
#   - Windows: COM7
#   - macOS: /dev/cu.usbmodem101
#   - Linux: /dev/ttyUSB0
SERIAL_PORT=auto
# SERIAL_PORT=COM7
# SERIAL_PORT=/dev/cu.usbmodem101

# Optional BLE device address if a BLE transport is added in your workflow.
# Not used in normal USB/TCP setups.
# BLE_ADDRESS=

# TCP settings only matter when `INTERFACE_TYPE=tcp`.
# Use them for a Meshtastic TCP endpoint or a compatible virtual node.
# TCP_NODE_HOST=127.0.0.1
# TCP_NODE_PORT=4404
# TCP_TIMEOUT=300

# Wait time for initial node config download before warning.
# Increase this if a slow node needs longer to deliver its full config.
# CONFIG_WAIT_TIMEOUT=60

# Poll cadence while waiting for initial config.
# Usually `1` is fine and should not need changes.
# POLL_INTERVAL=1

# ---------------------------------------------------------------------------
# Logging / console
# ---------------------------------------------------------------------------
# Base log level.
# Supported values:
#   DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Extra runtime detail.
# Shows more RX/TX/MQTT details in addition to the normal log level.
VERBOSE=false

# ---------------------------------------------------------------------------
# Hot reload of local `.env`
# ---------------------------------------------------------------------------
# If enabled, the wrapper script restarts the proxy when `.env` changes.
# Useful during tuning without manually restarting.
ENV_HOT_RELOAD_ENABLED=true

# How often the running proxy checks whether `.env` changed.
ENV_HOT_RELOAD_INTERVAL_SECONDS=2

# ---------------------------------------------------------------------------
# Listener mirror: Node -> MQTT JSON topics
# ---------------------------------------------------------------------------
# Enable JSON mirroring of packets received by the local node.
# Published topics can include:
#   <root>/proxy/rx/!<gateway>/all
#   <root>/proxy/rx/!<gateway>/port/<PORTNUM>
#   <root>/proxy/rx/!<gateway>/scope/dm
#   <root>/proxy/rx/!<gateway>/scope/group
MQTT_LISTENER_ENABLED=false

# Optional allowlist by Meshtastic `decoded.portnum`.
# Empty means: allow all port types unless excluded below.
# Examples:
#   TEXT_MESSAGE_APP
#   TEXT_MESSAGE_APP,TEXT_MESSAGE_COMPRESSED_APP
#   TEXT_MESSAGE_APP,POSITION_APP,TELEMETRY_APP,NODEINFO_APP
MQTT_LISTENER_PORTS=

# Optional blocklist by Meshtastic `decoded.portnum`.
# Good for noisy technical traffic you do not want mirrored.
# Typical examples:
#   ROUTING_APP,ADMIN_APP
MQTT_LISTENER_EXCLUDE_PORTS=

# Only mirror direct messages to this gateway node.
MQTT_LISTENER_DM_ONLY=false

# Only mirror broadcast/group messages.
MQTT_LISTENER_GROUP_ONLY=false

# Only mirror text-like packets.
# Good default for chat-style frontends.
MQTT_LISTENER_TEXT_ONLY=false

# Publish listener JSON topics with MQTT retain flag.
# Useful when UIs should see the latest known message state immediately.
MQTT_LISTENER_RETAIN=true

# Include the full raw packet JSON in the mirrored record.
# - true  = richer debugging data, larger payloads
# - false = smaller, cleaner JSON for apps
MQTT_LISTENER_INCLUDE_RAW=true

# Publish the generic `.../all` topic in addition to the scoped topics.
# Turn off if you want to avoid duplicate storage.
MQTT_LISTENER_PUBLISH_ALL=true

# Publish the `.../port/<PORTNUM>` topic in addition to the scoped topics.
MQTT_LISTENER_PUBLISH_PORT=true

# Publish the scope topics `.../scope/group` and `.../scope/dm`.
# This is the most useful switch for chat-like UIs.
MQTT_LISTENER_PUBLISH_SCOPE=true

# Publish ACK lifecycle topics with MQTT retain flag.
# ACK topics look like:
#   <root>/proxy/ack/!<gateway>/<client_ref>
MQTT_ACK_RETAIN=true

# Optional MQTT 5 Message Expiry for ALL broker publishes done by this proxy.
# This applies to listener JSON, ACK topics, node list exports, presence detail
# topics, and other proxy-generated MQTT publishes.
# Useful when retained topics should disappear automatically after a time.
MQTT_PUBLISH_EXPIRY_ENABLED=true

# Message expiry in seconds.
# `86400` = 24 hours
MQTT_PUBLISH_EXPIRY_SECONDS=86400

# ---------------------------------------------------------------------------
# Periodic node list export
# ---------------------------------------------------------------------------
# Export the known node database for selectors, dashboards, and remote tools.
# Published topics:
#   <root>/proxy/nodes/!<gateway>/all
#   <root>/proxy/nodes/!<gateway>/index
MQTT_NODE_LIST_ENABLED=true

# Export interval in seconds.
# `3600` = once per hour
MQTT_NODE_LIST_INTERVAL_SECONDS=3600

# Publish node list topics retained.
# Useful when a UI should instantly receive the current node index after connect.
MQTT_NODE_LIST_RETAIN=true

# ---------------------------------------------------------------------------
# Queue / forwarding behavior
# ---------------------------------------------------------------------------
# Delay between two packets sent from MQTT toward the radio.
# Keeps the radio side responsive while avoiding bursts.
MESH_TRANSMIT_DELAY=0.01

# Maximum queued MQTT->radio items before older traffic is dropped.
# Increase only if you expect large bursts and have RAM to spare.
MESH_MAX_QUEUE_SIZE=5000

# If true, MQTT traffic for channels not configured on the node may still be
# forwarded for passive monitoring / virtual channel scenarios.
# If false, unknown channels are dropped early.
MESH_ALLOW_UNCONFIGURED_CHANNELS=true

# By default, retained MQTT broker messages are NOT forwarded back to the radio,
# because they are usually historical state and can flood the queue on startup.
MQTT_FORWARD_RETAINED=false

# ---------------------------------------------------------------------------
# Health / recovery
# ---------------------------------------------------------------------------
# How long radio silence is tolerated before the proxy starts probing.
HEALTH_CHECK_ACTIVITY_TIMEOUT=300

# How often the proxy is allowed to send an active probe when the radio is quiet.
# Default behavior uses roughly half of the activity timeout.
HEALTH_CHECK_PROBE_INTERVAL=150

# How often the proxy prints a periodic health/status summary.
HEALTH_CHECK_STATUS_INTERVAL=60

# Delay before MQTT reconnect attempts after failures.
MQTT_RECONNECT_DELAY=5

# ---------------------------------------------------------------------------
# Extra MQTT roots / virtual channels
# ---------------------------------------------------------------------------
# Subscribe to additional encrypted MQTT roots and rewrite them into virtual
# channels for monitoring without RF crosstalk.
# Format:
#   root:prefix,root:prefix
# Example:
# EXTRA_MQTT_ROOTS=msh/US/NC:NC,msh/US/OH:Ohio
# EXTRA_MQTT_ROOTS=

# ---------------------------------------------------------------------------
# Notes for send commands
# ---------------------------------------------------------------------------
# The proxy listens for plaintext send commands on topics like:
#   <root>/proxy/send/!<gateway>/group/<channelIndex>
#   <root>/proxy/send/!<gateway>/direct/!<nodeId>
#
# Examples:
#   msh/EU_868/proxy/send/!49b65bc8/group/0
#   msh/EU_868/proxy/send/!49b65bc8/direct/!13c2288b
#
# JSON payload example:
#   {"text":"Hallo","channel":0,"want_ack":true,"hop_limit":3,"client_ref":"msg-001"}
#
# Important:
# - `want_ack=true` only produces MQTT ACK topics if `client_ref` is present.
# - ACK topic:
#     <root>/proxy/ack/!<gateway>/<client_ref>
