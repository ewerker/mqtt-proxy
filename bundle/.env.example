# Example .env for the Meshtastic MQTT Proxy bundle
# Copy to .env and adjust the values you need.
#
# In most local setups only SERIAL_PORT must be changed.
# MQTT broker settings are read from the connected Meshtastic node.

# ---------------------------------------------------------------------------
# Active example values
# ---------------------------------------------------------------------------
INTERFACE_TYPE=serial
SERIAL_PORT=COM7
LOG_LEVEL=INFO
VERBOSE=false

# Automatically restart the proxy when .env changes on disk
ENV_HOT_RELOAD_ENABLED=true
ENV_HOT_RELOAD_INTERVAL_SECONDS=2

# Mirror only text messages to MQTT JSON topics
MQTT_LISTENER_ENABLED=true
MQTT_LISTENER_PORTS=TEXT_MESSAGE_APP,TEXT_MESSAGE_COMPRESSED_APP
MQTT_LISTENER_EXCLUDE_PORTS=ROUTING_APP,ADMIN_APP,TELEMETRY_APP,POSITION_APP,NODEINFO_APP,NEIGHBORINFO_APP,TRACEROUTE_APP,WAYPOINT_APP,STORE_FORWARD_APP,RANGE_TEST_APP
MQTT_LISTENER_DM_ONLY=false
MQTT_LISTENER_GROUP_ONLY=false
MQTT_LISTENER_TEXT_ONLY=true
MQTT_LISTENER_RETAIN=true
MQTT_LISTENER_INCLUDE_RAW=false
MQTT_LISTENER_PUBLISH_ALL=false
MQTT_LISTENER_PUBLISH_PORT=false
MQTT_LISTENER_PUBLISH_SCOPE=true
MQTT_ACK_RETAIN=true

# Periodic node list for selector UIs
MQTT_NODE_LIST_ENABLED=true
MQTT_NODE_LIST_INTERVAL_SECONDS=3600
MQTT_NODE_LIST_RETAIN=true

# ---------------------------------------------------------------------------
# Optional alternatives
# ---------------------------------------------------------------------------
# INTERFACE_TYPE=tcp
# TCP_NODE_HOST=127.0.0.1
# TCP_NODE_PORT=4404
# TCP_TIMEOUT=300
#
# MESH_TRANSMIT_DELAY=0.01
# MESH_MAX_QUEUE_SIZE=5000
# MQTT_FORWARD_RETAINED=false
# HEALTH_CHECK_ACTIVITY_TIMEOUT=300
# HEALTH_CHECK_PROBE_INTERVAL=150
# HEALTH_CHECK_STATUS_INTERVAL=60
# MQTT_RECONNECT_DELAY=5
# EXTRA_MQTT_ROOTS=msh/US/NC:NC,msh/US/OH:Ohio
