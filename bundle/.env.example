# Example `.env` bundled with the Meshtastic MQTT Proxy.
# Copy this file to `.env` next to the executable / scripts and adjust only the
# values you really need.
#
# This bundle example is intentionally self-documented so users can understand
# the runtime options without opening the full docs.

# ---------------------------------------------------------------------------
# Typical local setup
# ---------------------------------------------------------------------------
# Use `serial` for a directly connected device.
INTERFACE_TYPE=serial

# `auto` tries to detect a likely Meshtastic USB serial port.
# Good first choice for Windows and macOS.
SERIAL_PORT=auto
# SERIAL_PORT=COM7
# SERIAL_PORT=/dev/cu.usbmodem101

# Base logging and optional extra detail.
LOG_LEVEL=INFO
VERBOSE=false

# Automatically restart after editing `.env`.
ENV_HOT_RELOAD_ENABLED=true
ENV_HOT_RELOAD_INTERVAL_SECONDS=2

# ---------------------------------------------------------------------------
# Listener mirror: receive text packets as JSON over MQTT
# ---------------------------------------------------------------------------
# Turn this on when a browser app or remote tool should consume received mesh
# packets from MQTT instead of talking to the radio directly.
MQTT_LISTENER_ENABLED=true

# Allow only text message ports by default for UI-friendly operation.
MQTT_LISTENER_PORTS=TEXT_MESSAGE_APP,TEXT_MESSAGE_COMPRESSED_APP

# Keep technical chatter out of the mirrored JSON topics unless you need it.
MQTT_LISTENER_EXCLUDE_PORTS=ROUTING_APP,ADMIN_APP,TELEMETRY_APP,POSITION_APP,NODEINFO_APP,NEIGHBORINFO_APP,TRACEROUTE_APP,WAYPOINT_APP,STORE_FORWARD_APP,RANGE_TEST_APP

# Scope filters:
# - DM only
# - group only
# Leave both false to mirror both types.
MQTT_LISTENER_DM_ONLY=false
MQTT_LISTENER_GROUP_ONLY=false

# Mirror only text-like packets.
MQTT_LISTENER_TEXT_ONLY=true

# Retain the mirrored JSON topics on the broker.
MQTT_LISTENER_RETAIN=true

# Keep payloads slim for UI use.
MQTT_LISTENER_INCLUDE_RAW=false

# Avoid duplicate storage and only publish group/direct scope topics.
MQTT_LISTENER_PUBLISH_ALL=false
MQTT_LISTENER_PUBLISH_PORT=false
MQTT_LISTENER_PUBLISH_SCOPE=true

# ACK topics remain retained so reconnecting clients still see the last state.
MQTT_ACK_RETAIN=true

# Optional MQTT 5 Message Expiry for proxy-published topics.
# 86400 seconds = 24 hours
MQTT_PUBLISH_EXPIRY_ENABLED=true
MQTT_PUBLISH_EXPIRY_SECONDS=86400

# ---------------------------------------------------------------------------
# Periodic node list for selectors and dashboards
# ---------------------------------------------------------------------------
MQTT_NODE_LIST_ENABLED=true
MQTT_NODE_LIST_INTERVAL_SECONDS=3600
MQTT_NODE_LIST_RETAIN=true

# ---------------------------------------------------------------------------
# Advanced / optional alternatives
# ---------------------------------------------------------------------------
# Use these only when your setup needs them.
#
# TCP instead of serial:
# INTERFACE_TYPE=tcp
# TCP_NODE_HOST=127.0.0.1
# TCP_NODE_PORT=4404
# TCP_TIMEOUT=300
#
# Optional BLE address placeholder:
# BLE_ADDRESS=
#
# Startup / config timing:
# CONFIG_WAIT_TIMEOUT=60
# POLL_INTERVAL=1
#
# Queue behavior:
# MESH_TRANSMIT_DELAY=0.01
# MESH_MAX_QUEUE_SIZE=5000
# MESH_ALLOW_UNCONFIGURED_CHANNELS=true
#
# Forward retained broker messages back toward the radio (normally keep false):
# MQTT_FORWARD_RETAINED=false
#
# Health / recovery:
# HEALTH_CHECK_ACTIVITY_TIMEOUT=300
# HEALTH_CHECK_PROBE_INTERVAL=150
# HEALTH_CHECK_STATUS_INTERVAL=60
# MQTT_RECONNECT_DELAY=5
#
# Additional roots for virtual channel monitoring:
# EXTRA_MQTT_ROOTS=msh/US/NC:NC,msh/US/OH:Ohio

# ---------------------------------------------------------------------------
# Send command reminder
# ---------------------------------------------------------------------------
# Group:
#   <root>/proxy/send/!<gateway>/group/<channelIndex>
# Direct:
#   <root>/proxy/send/!<gateway>/direct/!<nodeId>
#
# Example JSON payload:
#   {"text":"Hallo","channel":0,"want_ack":true,"hop_limit":3,"client_ref":"msg-001"}
#
# ACK topic:
#   <root>/proxy/ack/!<gateway>/<client_ref>
